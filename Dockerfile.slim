# vim: filetype=dockerfile
#
# Dockerfile.slim — single-arch CUDA build for Ollama KV Split.
#
# Uses the upstream CMake preset "CUDA 12" but overrides CMAKE_CUDA_ARCHITECTURES
# so only the target GPU arch is compiled. Defaults to sm_86 (RTX 30xx / Ampere).
# Override via --build-arg CUDA_ARCHITECTURES=89 (Ada), 90 (Hopper), etc.
#
# Produces a much smaller image than the upstream multi-arch Dockerfile.

ARG CUDA_ARCHITECTURES=86
ARG CMAKEVERSION=3.31.2
ARG NINJAVERSION=1.12.1

FROM --platform=linux/amd64 nvidia/cuda:12.8.0-devel-ubuntu22.04 AS base
ARG CMAKEVERSION
ARG NINJAVERSION
RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates curl unzip git ccache \
        build-essential gcc g++ \
    && rm -rf /var/lib/apt/lists/*
RUN curl -fsSL https://github.com/Kitware/CMake/releases/download/v${CMAKEVERSION}/cmake-${CMAKEVERSION}-linux-$(uname -m).tar.gz \
        | tar xz -C /usr/local --strip-components 1
RUN curl -fsSL -o /tmp/ninja.zip https://github.com/ninja-build/ninja/releases/download/v${NINJAVERSION}/ninja-linux.zip \
    && unzip /tmp/ninja.zip -d /usr/local/bin \
    && rm /tmp/ninja.zip
ENV CMAKE_GENERATOR=Ninja
ENV LDFLAGS=-s
ENV PATH=/usr/local/cuda/bin:$PATH

FROM base AS cuda
ARG CUDA_ARCHITECTURES
COPY CMakeLists.txt CMakePresets.json .
COPY ml/backend/ggml/ggml ml/backend/ggml/ggml
# Override the preset's multi-arch list with just the target arch.
RUN --mount=type=cache,target=/root/.ccache \
    cmake --preset 'CUDA 12' -DCMAKE_CUDA_ARCHITECTURES=${CUDA_ARCHITECTURES} \
    && cmake --build --preset 'CUDA 12' -- -l $(nproc) \
    && cmake --install build --component CUDA --strip

FROM base AS cpu
COPY CMakeLists.txt CMakePresets.json .
COPY ml/backend/ggml/ggml ml/backend/ggml/ggml
RUN --mount=type=cache,target=/root/.ccache \
    cmake --preset 'CPU' \
    && cmake --build --preset 'CPU' -- -l $(nproc) \
    && cmake --install build --component CPU --strip

FROM base AS build
WORKDIR /go/src/github.com/ollama/ollama
COPY go.mod go.sum .
RUN curl -fsSL https://golang.org/dl/go$(awk '/^go/ { print $2 }' go.mod).linux-amd64.tar.gz \
        | tar xz -C /usr/local
ENV PATH=/usr/local/go/bin:$PATH
RUN go mod download
COPY . .
ENV CGO_ENABLED=1
RUN --mount=type=cache,target=/root/.cache/go-build \
    go build -trimpath -buildmode=pie -buildvcs=false -ldflags="-w -s" -o /bin/ollama .

FROM --platform=linux/amd64 nvidia/cuda:12.8.0-runtime-ubuntu22.04 AS runtime-cuda
RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates libopenblas0 \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*
COPY --from=cpu   dist/lib/ollama /usr/lib/ollama
COPY --from=cuda  dist/lib/ollama /usr/lib/ollama
COPY --from=build /bin/ollama /usr/bin/ollama
ENV LD_LIBRARY_PATH=/usr/local/nvidia/lib:/usr/local/nvidia/lib64
ENV NVIDIA_DRIVER_CAPABILITIES=compute,utility
ENV NVIDIA_VISIBLE_DEVICES=all
ENV OLLAMA_HOST=0.0.0.0:11434
EXPOSE 11434
ENTRYPOINT ["/usr/bin/ollama"]
CMD ["serve"]
